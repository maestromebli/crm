# Скопіюйте в .env.local і підставте свої значення

# PostgreSQL (обовʼязково для лідів та інших модулів з Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/DBNAME"

# NextAuth (обовʼязково для входу)
# ВАЖЛИВО: значення має збігатися з тим, що в адресному рядку браузера.
# http://localhost:3000 і http://127.0.0.1:3000 — різні сайти; інакше вхід «не працює».
# Якщо в консолі [next-auth][CLIENT_FETCH_ERROR] Failed to fetch:
# — переконайтесь, що `pnpm dev` запущено і сторінка відкрита з того ж хоста, що в NEXTAUTH_URL;
# — з іншого ПК у мережі: NEXTAUTH_URL=http://ВАШ_IP:3000 (не localhost);
# — перевірте, що DATABASE_URL валідний (JWT-колбеки звертаються до БД).
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="згенеруйте_випадковий_рядок_32+_символів"

# Локально через Docker з кореня проєкту: pnpm db:up
# Тоді зазвичай:
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/postgres"
# Детальніше: docs/DATABASE.md

# SLA першого дотику (хвилини за замовчуванням 10; має пріоритет над годинами)
# LEAD_SLA_FIRST_TOUCH_MINUTES=10
# Застаріле: години (конвертується у хв, якщо хв не задано)
# LEAD_SLA_FIRST_TOUCH_HOURS=24

# Опційно: id користувача для фільтра «Призначені мені» (інакше береться demo@enver.local після seed)
# DEMO_LEAD_OWNER_ID=

# Google Maps — автодоповнення адреси при створенні події в календарі (Places API, ключ з Google Cloud Console)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# AI (опційно, для /api/ai/summary)
# AI_API_KEY=
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4.1-mini
