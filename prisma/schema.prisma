  deal       Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  employeeId String
  amount     Decimal  @db.Decimal(18, 2)
  type       String
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([dealId])
}

model Commission {
