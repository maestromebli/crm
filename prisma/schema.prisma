// --- ERP / додаткові сутності CRM (фінанси, закупівлі, кімната конструктора) ---

enum MoneyTransactionType {
  INCOME
  EXPENSE
}

enum MoneyTransactionStatus {
  PENDING
  PAID
  CANCELLED
}

enum MoneyTransactionCategory {
  PREPAYMENT
  FINAL_PAYMENT
  MATERIALS
  SALARY
  OTHER
}

model MoneyTransaction {
  id          String                  @id @default(cuid())
  dealId      String
  deal        Deal                    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type        MoneyTransactionType
  category    MoneyTransactionCategory
  amount      Decimal                 @db.Decimal(18, 2)
  currency    String                  @default("UAH")
  status      MoneyTransactionStatus
  paidAt      DateTime?
  dueDate     DateTime?
  description String?                 @db.Text
  createdById String?
  createdBy   User?                   @relation("MoneyTransactionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([dealId])
  @@index([paidAt])
}

model FinanceTransaction {
  id          String   @id @default(cuid())
  dealId      String
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type        String
  amount      Decimal  @db.Decimal(18, 2)
  currency    String   @default("UAH")
  date        DateTime
  status      String
  category    String
  affectsCash Boolean  @default(true)
  createdById String?
  createdBy   User?    @relation("FinanceTransactionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dealId])
}

model OperatingExpense {
  id            String   @id @default(cuid())
  dealId        String
  deal          Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  title         String
  category      String
  amountActual  Decimal? @db.Decimal(18, 2)
  amountPlanned Decimal? @db.Decimal(18, 2)
  status        String
  expenseDate   DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([dealId])
}

model PayrollEntry {
  id         String   @id @default(cuid())
  dealId     String
  deal       Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  employeeId String
  amount     Decimal  @db.Decimal(18, 2)
  type       String
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([dealId])
}

model Commission {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  userId    String
  amount    Decimal  @db.Decimal(18, 2)
  percent   Decimal? @db.Decimal(9, 4)
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
}

model ProcurementRequest {
  id           String                   @id @default(cuid())
  dealId       String
  deal         Deal                     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  source       String
  status       String
  priority     String?
  neededByDate DateTime?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  items        ProcurementRequestItem[]

  @@index([dealId])
}

model ProcurementRequestItem {
  id           String             @id @default(cuid())
  requestId    String
  request      ProcurementRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  name         String?
  qtyPlanned   Float?
  qtyOrdered   Float?
  qtyReceived  Float?
  costPlanned  Decimal            @db.Decimal(18, 2)
  costActual   Decimal            @db.Decimal(18, 2)
  status       String?

  @@index([requestId])
  @@map("ProcurementItem")
}

model PurchaseOrder {
  id            String    @id @default(cuid())
  dealId        String
  deal          Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  totalAmount   Decimal   @db.Decimal(18, 2)
  status        String
  expectedDate  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([dealId])
}

model Supplier {
  id                 String             @id @default(cuid())
  name               String
  category           String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  dealPurchaseOrders DealPurchaseOrder[]
  materials          Material[]
}

model DealPurchaseOrder {
  id           String   @id @default(cuid())
  orderNumber  String   @unique
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  dealId       String
  deal         Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  itemsJson    Json
  total        Decimal  @db.Decimal(18, 2)
  status       String
  expectedDate DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([dealId])
}

enum CrmInvoiceType {
  INCOMING
  OUTGOING
  PREPAYMENT_70
  FINAL_30
  CUSTOM
}

enum CrmInvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

model Invoice {
  id          String         @id @default(cuid())
  dealId      String
  deal        Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type        CrmInvoiceType
  /** Загальна сума до сплати (з ПДВ, якщо застосовується). */
  amount      Decimal        @db.Decimal(18, 2)
  status      CrmInvoiceStatus @default(DRAFT)
  dueDate     DateTime?
  pdfUrl      String?
  /** Номер рахунку / первинки для обліку. */
  documentNumber String?     @db.VarChar(64)
  issueDate   DateTime?
  counterpartyName  String?
  counterpartyEdrpou String?  @db.VarChar(12)
  /** Ставка ПДВ, % (наприклад 20.00). */
  vatRatePercent    Decimal?  @db.Decimal(5, 2)
  /** Без ПДВ. */
  amountWithoutVat  Decimal?  @db.Decimal(18, 2)
  vatAmount         Decimal?  @db.Decimal(18, 2)
  createdById String?
  createdBy   User?          @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([dealId])
}

/** Класифікація рахунків бухгалтерського плану (спрощена). */
enum LedgerAccountKind {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum FinanceJournalEntryStatus {
  DRAFT
  POSTED
  VOIDED
}

/** Рахунок з плану рахунків (подвійний запис). */
model LedgerAccount {
  id        String            @id @default(cuid())
  code      String            @unique @db.VarChar(16)
  name      String
  kind      LedgerAccountKind
  isActive  Boolean           @default(true)
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  lines     FinanceJournalLine[]
}

/** Заголовок проводки: дебет = кредит. */
model FinanceJournalEntry {
  id          String                    @id @default(cuid())
  dealId      String?
  deal        Deal?                     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  postedAt    DateTime
  status      FinanceJournalEntryStatus @default(DRAFT)
  memo        String?                   @db.Text
  createdById String?
  createdBy   User?                     @relation("FinanceJournalEntryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  lines       FinanceJournalLine[]
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@index([dealId])
  @@index([postedAt])
  @@index([status])
}

/** Рядок проводки: одна сторона — дебет або кредит. */
model FinanceJournalLine {
  id              String              @id @default(cuid())
  entryId         String
  entry           FinanceJournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  ledgerAccountId String
  ledgerAccount   LedgerAccount       @relation(fields: [ledgerAccountId], references: [id], onDelete: Restrict)
  debitAmount     Decimal             @default(0) @db.Decimal(18, 2)
  creditAmount    Decimal             @default(0) @db.Decimal(18, 2)
  lineMemo        String?             @db.VarChar(512)

  @@index([entryId])
  @@index([ledgerAccountId])
}

model PaymentPlanEntry {
  id              String   @id @default(cuid())
  dealId          String?
  deal            Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  amount          Decimal  @db.Decimal(18, 2)
  remainingAmount Decimal? @db.Decimal(18, 2)
  dueDate         DateTime
  status          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([dealId])
}

model Project {
  id        String   @id @default(cuid())
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  code      String?
  title     String?
  status    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
}

model DealPaymentPlan {
  id              String   @id @default(cuid())
  dealId          String   @unique
  deal            Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  stepsJson       Json
  reasonIfChanged String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Material {
  id         String    @id @default(cuid())
  name       String
  code       String?
  price      Float?
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  stockItems StockItem[]
}

model StockItem {
  id         String    @id @default(cuid())
  sku        String?
  materialId String?
  material   Material? @relation(fields: [materialId], references: [id], onDelete: SetNull)
  quantity   Float     @default(0)
  reserved   Float     @default(0)
  storageZoneId String?
  storageZone   WarehouseStorageZone? @relation(fields: [storageZoneId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  stockReservations StockReservation[]
  stockMovements    WarehouseStockMovement[]

  @@index([storageZoneId])
}

/** Зона / стелаж / ряд — штрихкод для сканерів ТСД. */
model WarehouseStorageZone {
  id        String   @id @default(cuid())
  name      String
  /** Короткий код (A1, R2-Б) для етикеток. */
  code      String
  /** Унікальний штрихкод / QR payload. */
  barcode   String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockItems StockItem[]

  movementsFrom WarehouseStockMovement[] @relation("MovementFromZone")
  movementsTo   WarehouseStockMovement[] @relation("MovementToZone")

  @@index([code])
}

enum WarehouseMovementKind {
  RECEIPT
  ISSUE
  TRANSFER
  ADJUSTMENT
  RESERVE
  UNRESERVE
}

enum WarehouseRefKind {
  PURCHASE_ORDER
  PRODUCTION_TASK
  PRODUCTION_FLOW
  MANUAL
  DEAL
}

/** Журнал руху по складу (аудит). */
model WarehouseStockMovement {
  id            String               @id @default(cuid())
  stockItemId   String
  stockItem     StockItem            @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  kind          WarehouseMovementKind
  /** Зміна кількості: + надходження / резерв, − вибуття / зняття резерву. */
  quantityDelta Float
  refKind       WarehouseRefKind?
  refId         String?
  note          String?              @db.Text
  fromZoneId    String?
  fromZone      WarehouseStorageZone? @relation("MovementFromZone", fields: [fromZoneId], references: [id], onDelete: SetNull)
  toZoneId      String?
  toZone        WarehouseStorageZone? @relation("MovementToZone", fields: [toZoneId], references: [id], onDelete: SetNull)
  createdById   String?
  createdBy     User?                 @relation("WarehouseStockMovementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime              @default(now())

  @@index([stockItemId, createdAt])
  @@index([createdAt])
  @@index([refKind, refId])
}

enum StockReservationStatus {
  ACTIVE
  RELEASED
}

/** Рядок резерву під виробничу задачу або вручну. */
model StockReservation {
  id         String   @id @default(cuid())
  stockItemId String
  stockItem  StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  productionTaskId String?
  productionTask   ProductionTask? @relation(fields: [productionTaskId], references: [id], onDelete: Cascade)
  quantity   Float
  status     StockReservationStatus @default(ACTIVE)
  note       String?                @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([stockItemId, status])
  @@index([productionTaskId])
}

enum ConstructorRoomStatus {
  DRAFT
  PENDING_ASSIGNMENT
  SENT_TO_CONSTRUCTOR
  IN_PROGRESS
  DELIVERED
  REVIEWED
}

model DealConstructorRoom {
  id                       String                @id @default(cuid())
  dealId                   String                @unique
  deal                     Deal                  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  status                   ConstructorRoomStatus @default(DRAFT)
  publicToken              String                @unique
  assignedById             String?
  assignedUserId           String?
  externalConstructorLabel String?
  telegramInviteUrl        String?
  telegramChatId           String?
  aiQaJson                 Json?
  priority                 TaskPriority          @default(NORMAL)
  dueAt                    DateTime?
  sentToConstructorAt      DateTime?
  deliveredAt              DateTime?
  reviewedAt               DateTime?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  assignedBy               User?                 @relation("DealConstructorRoomAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  assignedUser             User?                 @relation("DealConstructorRoomAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  messages                 DealConstructorRoomMessage[]
