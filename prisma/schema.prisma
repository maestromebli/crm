model LedgerAccount {
  id        String               @id @default(cuid())
  code      String               @unique @db.VarChar(16)
  name      String
  kind      LedgerAccountKind
  isActive  Boolean              @default(true)
  sortOrder Int                  @default(0)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  lines     FinanceJournalLine[]
}

/**
 * Заголовок проводки: дебет = кредит.
 */
model FinanceJournalEntry {
  id          String                    @id @default(cuid())
  dealId      String?
  deal        Deal?                     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  postedAt    DateTime
  status      FinanceJournalEntryStatus @default(DRAFT)
  memo        String?                   @db.Text
  createdById String?
  createdBy   User?                     @relation("FinanceJournalEntryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  lines       FinanceJournalLine[]
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@index([dealId])
  @@index([postedAt])
  @@index([status])
}

/**
 * Рядок проводки: одна сторона — дебет або кредит.
 */
model FinanceJournalLine {
  id              String              @id @default(cuid())
  entryId         String
  entry           FinanceJournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  ledgerAccountId String
  ledgerAccount   LedgerAccount       @relation(fields: [ledgerAccountId], references: [id], onDelete: Restrict)
  debitAmount     Decimal             @default(0) @db.Decimal(18, 2)
  creditAmount    Decimal             @default(0) @db.Decimal(18, 2)
  lineMemo        String?             @db.VarChar(512)

  @@index([entryId])
  @@index([ledgerAccountId])
}

model PaymentPlanEntry {
  id              String   @id @default(cuid())
  dealId          String?
  deal            Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  amount          Decimal  @db.Decimal(18, 2)
  remainingAmount Decimal? @db.Decimal(18, 2)
  dueDate         DateTime
  status          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([dealId])
}

model Project {
  id        String   @id @default(cuid())
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  code      String?
  title     String?
  status    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
}

model DealPaymentPlan {
  id              String   @id @default(cuid())
  dealId          String   @unique
  deal            Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  stepsJson       Json
  reasonIfChanged String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Material {
  id         String      @id @default(cuid())
  name       String
  code       String?
  price      Float?
  supplierId String?
  supplier   Supplier?   @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  stockItems StockItem[]
}

model StockItem {
  id            String                @id @default(cuid())
  sku           String?
  materialId    String?
  material      Material?             @relation(fields: [materialId], references: [id], onDelete: SetNull)
  quantity      Float                 @default(0)
  reserved      Float                 @default(0)
  storageZoneId String?
  storageZone   WarehouseStorageZone? @relation(fields: [storageZoneId], references: [id], onDelete: SetNull)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  stockReservations StockReservation[]
  stockMovements    WarehouseStockMovement[]

  @@index([storageZoneId])
}

/**
 * Зона / стелаж / ряд — штрихкод для сканерів ТСД.
 */
model WarehouseStorageZone {
  id        String   @id @default(cuid())
  name      String
  /**
   * Короткий код (A1, R2-Б) для етикеток.
   */
  code      String
  /**
   * Унікальний штрихкод / QR payload.
   */
  barcode   String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockItems StockItem[]

  movementsFrom WarehouseStockMovement[] @relation("MovementFromZone")
  movementsTo   WarehouseStockMovement[] @relation("MovementToZone")

  @@index([code])
}

enum WarehouseMovementKind {
  RECEIPT
  ISSUE
  TRANSFER
  ADJUSTMENT
  RESERVE
  UNRESERVE
}

enum WarehouseRefKind {
  PURCHASE_ORDER
  PRODUCTION_TASK
  PRODUCTION_FLOW
  MANUAL
  DEAL
}

/**
 * Журнал руху по складу (аудит).
 */
model WarehouseStockMovement {
  id            String                @id @default(cuid())
  stockItemId   String
  stockItem     StockItem             @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  kind          WarehouseMovementKind
  /**
   * Зміна кількості: + надходження / резерв, − вибуття / зняття резерву.
   */
  quantityDelta Float
  refKind       WarehouseRefKind?
  refId         String?
  note          String?               @db.Text
  fromZoneId    String?
  fromZone      WarehouseStorageZone? @relation("MovementFromZone", fields: [fromZoneId], references: [id], onDelete: SetNull)
  toZoneId      String?
  toZone        WarehouseStorageZone? @relation("MovementToZone", fields: [toZoneId], references: [id], onDelete: SetNull)
  createdById   String?
  createdBy     User?                 @relation("WarehouseStockMovementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime              @default(now())

  @@index([stockItemId, createdAt])
  @@index([createdAt])
  @@index([refKind, refId])
}

enum StockReservationStatus {
  ACTIVE
  RELEASED
}

/**
 * Рядок резерву під виробничу задачу або вручну.
 */
model StockReservation {
  id               String                 @id @default(cuid())
  stockItemId      String
  stockItem        StockItem              @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  productionTaskId String?
  productionTask   ProductionTask?        @relation(fields: [productionTaskId], references: [id], onDelete: Cascade)
  quantity         Float
  status           StockReservationStatus @default(ACTIVE)
  note             String?                @db.Text
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([stockItemId, status])
  @@index([productionTaskId])
}

enum ConstructorRoomStatus {
  DRAFT
  PENDING_ASSIGNMENT
  SENT_TO_CONSTRUCTOR
  IN_PROGRESS
  DELIVERED
  REVIEWED
}

model DealConstructorRoom {
  id                       String                       @id @default(cuid())
  dealId                   String                       @unique
  deal                     Deal                         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  status                   ConstructorRoomStatus        @default(DRAFT)
  publicToken              String                       @unique
  assignedById             String?
  assignedUserId           String?
  externalConstructorLabel String?
  telegramInviteUrl        String?
  telegramChatId           String?
  aiQaJson                 Json?
  priority                 TaskPriority                 @default(NORMAL)
  dueAt                    DateTime?
  sentToConstructorAt      DateTime?
  deliveredAt              DateTime?
  reviewedAt               DateTime?
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt
  assignedBy               User?                        @relation("DealConstructorRoomAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  assignedUser             User?                        @relation("DealConstructorRoomAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  messages                 DealConstructorRoomMessage[]
}

model DealConstructorRoomMessage {
  id          String              @id @default(cuid())
  roomId      String
  room        DealConstructorRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  body        String              @db.Text
  author      String              @default("INTERNAL")
  createdById String?
  createdBy   User?               @relation("ConstructorRoomMessageAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime            @default(now())

  @@index([roomId])
}

model ConstructorWorkspace {
  id                        String                     @id @default(cuid())
  dealId                    String                     @unique
  deal                      Deal                       @relation(fields: [dealId], references: [id], onDelete: Cascade)
  productionFlowId          String?                    @unique
  productionFlow            ProductionFlow?            @relation(fields: [productionFlowId], references: [id], onDelete: SetNull)
  productionOrderId         String?
  assignedConstructorUserId String?
  assignedConstructorUser   User?                      @relation("ConstructorWorkspaceAssignedConstructor", fields: [assignedConstructorUserId], references: [id], onDelete: SetNull)
  assignedByUserId          String?
  assignedByUser            User?                      @relation("ConstructorWorkspaceAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  status                    ConstructorWorkspaceStatus @default(NOT_ASSIGNED)
  priority                  TaskPriority               @default(NORMAL)
  dueDate                   DateTime?
  startedAt                 DateTime?
  submittedAt               DateTime?
  approvedAt                DateTime?
  handedOffAt               DateTime?
  snapshotOutdated          Boolean                    @default(false)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  techSpec       ConstructorTechSpec?
  questions      ConstructorQuestion[]
  files          ConstructorFile[]
  versions       ConstructorVersion[]
  reviews        ConstructorReview[]
  checklistItems ConstructorChecklistItem[]
  zones          ConstructorZoneProgress[]
  aiInsights     ConstructorAIInsight[]
  timeline       ConstructorTimelineEvent[]

  @@index([status, dueDate])
  @@index([assignedConstructorUserId, status])
}

model ConstructorTechSpec {
  id                        String               @id @default(cuid())
  workspaceId               String               @unique
  workspace                 ConstructorWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  generalInfoJson           Json?
  zonesJson                 Json?
  modulesJson               Json?
  materialsJson             Json?
  facadesJson               Json?
  fittingsJson              Json?
  lightingAndAppliancesJson Json?
  installationNotesJson     Json?
  risksJson                 Json?
  requiredAttentionJson     Json?
  sourceSnapshotJson        Json?
  approvedDataSnapshotJson  Json?
  createdByUserId           String?
  createdByUser             User?                @relation("ConstructorTechSpecCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId           String?
  updatedByUser             User?                @relation("ConstructorTechSpecUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
}

model ConstructorQuestion {
  id               String                      @id @default(cuid())
  workspaceId      String
  workspace        ConstructorWorkspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByUserId  String?
  createdByUser    User?                       @relation("ConstructorQuestionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  assignedToUserId String?
  assignedToUser   User?                       @relation("ConstructorQuestionAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  assignedRole     String?
  category         ConstructorQuestionCategory @default(OTHER)
  priority         ConstructorQuestionPriority @default(MEDIUM)
  status           ConstructorQuestionStatus   @default(OPEN)
  title            String
  description      String                      @db.Text
  answerText       String?                     @db.Text
  answeredByUserId String?
  answeredByUser   User?                       @relation("ConstructorQuestionAnsweredBy", fields: [answeredByUserId], references: [id], onDelete: SetNull)
  answeredAt       DateTime?
  isCritical       Boolean                     @default(false)
  isPinned         Boolean                     @default(false)
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  closedAt         DateTime?

  @@index([workspaceId, status])
  @@index([assignedToUserId, status])
}

model ConstructorVersion {
  id                String                   @id @default(cuid())
  workspaceId       String
  workspace         ConstructorWorkspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  versionNumber     Int
  versionCode       String
  type              ConstructorVersionType   @default(DRAFT)
  status            ConstructorVersionStatus @default(PREPARING)
  summary           String                   @db.Text
  isCurrent         Boolean                  @default(false)
  submittedByUserId String?
  submittedByUser   User?                    @relation("ConstructorVersionSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  submittedAt       DateTime?
  reviewedByUserId  String?
  reviewedByUser    User?                    @relation("ConstructorVersionReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewedAt        DateTime?
  approvedAt        DateTime?
  returnReason      String?                  @db.Text
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  files      ConstructorFile[]
  reviews    ConstructorReview[]
  aiInsights ConstructorAIInsight[]

  @@unique([workspaceId, versionNumber])
  @@index([workspaceId, status])
}

model ConstructorFile {
  id               String                  @id @default(cuid())
  workspaceId      String
  workspace        ConstructorWorkspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  versionId        String?
  version          ConstructorVersion?     @relation(fields: [versionId], references: [id], onDelete: SetNull)
  uploadedByUserId String?
  uploadedByUser   User?                   @relation("ConstructorFileUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  fileStorageKey   String?
  fileUrl          String?
  originalName     String
  mimeType         String
  extension        String
  sizeBytes        Int?
  fileCategory     ConstructorFileCategory @default(OTHER)
  versionLabel     String?
  isApproved       Boolean                 @default(false)
  isCurrent        Boolean                 @default(true)
  isArchived       Boolean                 @default(false)
  isImportant      Boolean                 @default(false)
  comment          String?                 @db.Text
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([workspaceId, fileCategory])
  @@index([versionId])
}

model ConstructorReview {
  id               String                    @id @default(cuid())
  workspaceId      String
  workspace        ConstructorWorkspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  versionId        String
  version          ConstructorVersion        @relation(fields: [versionId], references: [id], onDelete: Cascade)
  reviewedByUserId String?
  reviewedByUser   User?                     @relation("ConstructorReviewReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  decision         ConstructorReviewDecision
  comment          String?                   @db.Text
  severity         ConstructorReviewSeverity @default(INFO)
  checklistJson    Json?
  remarksJson      Json?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@index([workspaceId, createdAt])
  @@index([versionId])
}

model ConstructorChecklistItem {
  id                String               @id @default(cuid())
  workspaceId       String
  workspace         ConstructorWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  code              String
  title             String
  description       String?              @db.Text
  isRequired        Boolean              @default(true)
  isCompleted       Boolean              @default(false)
  completedAt       DateTime?
  completedByUserId String?
  completedByUser   User?                @relation("ConstructorChecklistCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)
  sortOrder         Int                  @default(0)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([workspaceId, code])
  @@index([workspaceId, isCompleted])
}

model ConstructorZoneProgress {
  id              String                @id @default(cuid())
  workspaceId     String
  workspace       ConstructorWorkspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  zoneKey         String
  zoneTitle       String
  progressPercent Int                   @default(0)
  status          ConstructorZoneStatus @default(NOT_STARTED)
  notes           String?               @db.Text
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([workspaceId, zoneKey])
  @@index([workspaceId, status])
}

model ConstructorAIInsight {
  id            String                       @id @default(cuid())
  workspaceId   String
  workspace     ConstructorWorkspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  versionId     String?
  version       ConstructorVersion?          @relation(fields: [versionId], references: [id], onDelete: SetNull)
  type          ConstructorAIInsightType
  severity      ConstructorAIInsightSeverity @default(MEDIUM)
  title         String
  description   String                       @db.Text
  sourceRefJson Json?
  isResolved    Boolean                      @default(false)
  resolvedAt    DateTime?
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt

  @@index([workspaceId, createdAt])
}

model ConstructorTimelineEvent {
  id           String               @id @default(cuid())
  workspaceId  String
  workspace    ConstructorWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorUserId  String?
  actorUser    User?                @relation("ConstructorTimelineActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  eventType    String
  title        String
  description  String?              @db.Text
  metadataJson Json?
  createdAt    DateTime             @default(now())

  @@index([workspaceId, createdAt])
}

enum CommEntityType {
  LEAD
  DEAL
  CONTACT
  CLIENT
}

model CommConversationInsight {
  id                        String         @id @default(cuid())
  threadId                  String         @unique
  entityType                CommEntityType
  entityId                  String
  summaryShort              String         @db.Text
  summaryDetailed           String         @db.Text
  clientIntent              String?
  extractedNeedsJson        Json?
  extractedMeasurementsJson Json?
  extractedMaterialsJson    Json?
  extractedBudgetJson       Json?
  extractedDatesJson        Json?
  extractedRisksJson        Json?
  missingInfoJson           Json?
  recommendedNextStep       String?
  recommendedReply          String?
  confidenceScore           Float?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
}

enum AiDetectedFileCategory {
  PROJECT
  PHOTO
  DIMENSIONS
  MEASUREMENT
  COMMERCIAL_PROPOSAL
  CONTRACT
  INVOICE
  TECHNICAL
  VISUALIZATION
  MESSENGER_SCREENSHOT
  OTHER
}

enum AiFileProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  SKIPPED_NO_LOCAL_FILE
  SKIPPED_NO_AI_KEY
}

model FileAiExtraction {
  id                    String                  @id @default(cuid())
  attachmentId          String                  @unique
  attachment            Attachment              @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  entityType            AttachmentEntityType
  entityId              String
  mimeType              String
  originalFilename      String
  userConfirmedCategory AiDetectedFileCategory?
  processingStatus      AiFileProcessingStatus  @default(PENDING)
  processingError       String?                 @db.Text
  extractedText         String?                 @db.Text
  detectedCategory      AiDetectedFileCategory?
  shortSummary          String?                 @db.Text
  detailedSummary       String?                 @db.Text
  extractedEntities     Json?
  extractedMeasurements Json?
  extractedAmounts      Json?
  extractedDates        Json?
  extractedPeople       Json?
  extractedMaterials    Json?
  extractedRisks        Json?
  confidenceScore       Float?
  processedAt           DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
}

model AiAssistantLog {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action       String
  entityType   String?
  entityId     String?
  model        String?
  tokensApprox Int?
  metadata     Json?
  ok           Boolean  @default(true)
  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model DealFinanceSnapshot {
  id          String   @id @default(cuid())
  dealId      String
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  revenueUah  Decimal  @db.Decimal(18, 2)
  expensesUah Decimal  @db.Decimal(18, 2)
  profitUah   Decimal  @db.Decimal(18, 2)
  marginPct   Decimal? @db.Decimal(9, 4)
  source      String
  metaJson    Json?
  createdAt   DateTime @default(now())

  @@index([dealId, createdAt])
}

// --- Communication hub (threads / messages; optional until channels are wired) ---

enum CommChannelType {
  TELEGRAM
  INSTAGRAM
  CALL_LOG
  INTERNAL_NOTE
  OTHER
  WHATSAPP
  VIBER
  SMS
  EMAIL
  WEBCHAT
}

enum CommMessageDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum CommMessageKind {
  TEXT
  ATTACHMENT
  NOTE
  OTHER
  IMAGE
  FILE
  VOICE
  SYSTEM
}

enum CommSenderType {
  CLIENT
  MANAGER
  SYSTEM
  INTERNAL
  BOT
}

enum CommThreadStatus {
  OPEN
  ARCHIVED
  NEEDS_REPLY
  WAITING_CLIENT
  COMPLETED
  FOLLOW_UP_OVERDUE
  DORMANT
}

model CommChannelAccount {
  id           String          @id @default(cuid())
  type         CommChannelType
  title        String
  syncStatus   String          @default("DISCONNECTED")
  lastSyncedAt DateTime?
  lastError    String?         @db.Text
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model CommThread {
  id                 String           @id @default(cuid())
  entityType         CommEntityType
  entityId           String
  channelType        CommChannelType
  title              String?
  participantName    String?
  lastMessageAt      DateTime?
  unreadCount        Int              @default(0)
  status             CommThreadStatus @default(OPEN)
  needsReply         Boolean          @default(false)
  followUpAt         DateTime?
  aiSummary          String?          @db.Text
  aiSummaryUpdatedAt DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  messages           CommMessage[]

  @@unique([entityType, entityId, channelType])
  @@index([entityType, entityId])
  @@index([lastMessageAt])
}

model CommMessage {
  id                  String               @id @default(cuid())
  threadId            String
  thread              CommThread           @relation(fields: [threadId], references: [id], onDelete: Cascade)
  direction           CommMessageDirection
  senderName          String?
  text                String               @db.Text
  sentAt              DateTime             @default(now())
  messageKind         CommMessageKind      @default(TEXT)
  senderType          CommSenderType?
  legacyLeadMessageId String?              @unique

  @@index([threadId, sentAt])
}

model CommFollowUpSuggestion {
  id           String         @id @default(cuid())
  entityType   CommEntityType
  entityId     String
  reason       String         @db.Text
  draftMessage String?        @db.Text
  dueAt        DateTime?
  urgency      String?
  status       String         @default("OPEN")
  suggestedAt  DateTime       @default(now())

  @@index([entityType, entityId, status])
}

enum LeadHubStatus {
  DRAFT
  ACTIVE
  CONVERTED
  ARCHIVED
}

model LeadHubSession {
  id               String        @id @default(cuid())
  title            String?
  status           LeadHubStatus @default(DRAFT)
  previewImage     String?
  leadId           String?
  pricingSessionId String        @unique
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  lead           Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  pricingSession PricingSession @relation(fields: [pricingSessionId], references: [id], onDelete: Cascade)
  files          LeadHubFile[]

  @@index([status, updatedAt])
  @@index([leadId])
}

model LeadHubFile {
  id           String   @id @default(cuid())
  sessionId    String
  attachmentId String
  role         String
  createdAt    DateTime @default(now())

  session    LeadHubSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  attachment Attachment     @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@index([sessionId, role])
  @@index([attachmentId])
}

model PricingSession {
  id              String   @id @default(cuid())
  entityType      String
  entityId        String
  currency        String
  activeVersionId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  versions      PricingVersion[]
  leadHub       LeadHubSession?
  activeVersion PricingVersion? @relation("PricingSessionActiveVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, updatedAt])
}

model PricingVersion {
  id               String   @id @default(cuid())
  pricingSessionId String
  versionNumber    Int
  totalsJson       Json
  summaryJson      Json
  createdAt        DateTime @default(now())

  pricingSession PricingSession @relation(fields: [pricingSessionId], references: [id], onDelete: Cascade)
  items          PricingItem[]
  activeFor      PricingSession[] @relation("PricingSessionActiveVersion")

  @@unique([pricingSessionId, versionNumber])
  @@index([pricingSessionId, createdAt])
}

model PricingItem {
  id               String   @id @default(cuid())
  pricingVersionId String
  name             String
  quantity         Float
  inputJson        Json
  resultJson       Json
  createdAt        DateTime @default(now())

  pricingVersion PricingVersion @relation(fields: [pricingVersionId], references: [id], onDelete: Cascade)

  @@index([pricingVersionId])
}

enum ContractStatus {
  DRAFT
  FILLED
  UNDER_REVIEW
  APPROVED
  SENT_TO_CUSTOMER
  VIEWED_BY_CUSTOMER
  CUSTOMER_SIGNING
  CUSTOMER_SIGNED
  FULLY_SIGNED
  REJECTED
  NEEDS_REVISION
  ARCHIVED
}

enum ContractDocumentType {
  CONTRACT_HTML
  SPECIFICATION_HTML
  CONTRACT_PDF
  SPECIFICATION_PDF
  FINAL_SIGNED_PDF
}

enum ContractShareLinkStatus {
  ACTIVE
  EXPIRED
  REVOKED
  USED
}

enum SignatureSessionStatus {
  CREATED
  PENDING
  IN_PROGRESS
  SIGNED
  DECLINED
  EXPIRED
  ERROR
}

model Customer {
  id           String   @id @default(cuid())
  fullName     String
  taxId        String?
  passportData String?
  phone        String?
  email        String?
  address      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contracts Contract[]

  @@index([phone])
  @@index([email])
}

model Quotation {
  id                 String   @id @default(cuid())
  externalProposalId String?  @unique
  dealId             String?
  deal               Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  currency           String   @default("UAH")
  discountAmount     Decimal  @default(0) @db.Decimal(18, 2)
  totalAmount        Decimal  @default(0) @db.Decimal(18, 2)
  notes              String?  @db.Text
  createdById        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  items     QuotationItem[]
  contracts Contract[]

  @@index([dealId, createdAt])
}

model QuotationItem {
  id          String   @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  lineNumber  Int
  productName String
  article     String?
  unit        String
  quantity    Decimal  @db.Decimal(18, 3)
  unitPrice   Decimal  @db.Decimal(18, 2)
  lineTotal   Decimal  @db.Decimal(18, 2)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([quotationId, lineNumber])
}

model Contract {
  id                     String         @id @default(cuid())
  dealId                 String
  deal                   Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  customerId             String
  customer               Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  quotationId            String?
  quotation              Quotation?     @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  status                 ContractStatus @default(DRAFT)
  templateKey            String         @default("supply-contract-v1")
  contractNumber         String
  contractDate           DateTime
  customerType           String?
  objectAddress          String?
  deliveryAddress        String?
  totalAmount            Decimal        @default(0) @db.Decimal(18, 2)
  advanceAmount          Decimal        @default(0) @db.Decimal(18, 2)
  remainingAmount        Decimal        @default(0) @db.Decimal(18, 2)
  productionLeadTimeDays Int?
  installationLeadTime   String?
  paymentTerms           String?
  warrantyMonths         Int?
  managerComment         String?        @db.Text
  specialConditions      String?        @db.Text
  supplierSignerName     String?
  supplierSignerBasis    String?
  approvedAt             DateTime?
  sentToCustomerAt       DateTime?
  viewedByCustomerAt     DateTime?
  customerSignedAt       DateTime?
  fullySignedAt          DateTime?
  archivedAt             DateTime?
  createdById            String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  fieldValues       ContractFieldValue[]
  specification     ContractSpecification?
  documents         ContractDocument[]
  shareLinks        ContractShareLink[]
  auditLogs         ContractAuditLog[]
  signatureSessions SignatureSession[]

  @@index([dealId, status])
  @@index([customerId])
  @@index([quotationId])
}

model ContractFieldValue {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  fieldKey   String
  fieldValue String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([contractId, fieldKey])
  @@index([contractId])
}

model ContractSpecification {
  id                 String   @id @default(cuid())
  contractId         String   @unique
  contract           Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  subtotal           Decimal  @default(0) @db.Decimal(18, 2)
  total              Decimal  @default(0) @db.Decimal(18, 2)
  totalFormattedText String?
  currency           String   @default("UAH")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  items ContractSpecificationItem[]
}

model ContractSpecificationItem {
  id              String               @id @default(cuid())
  specificationId String
  specification   ContractSpecification @relation(fields: [specificationId], references: [id], onDelete: Cascade)
  lineNumber      Int
  productName     String
  unit            String
  quantity        Decimal              @db.Decimal(18, 3)
  unitPrice       Decimal              @db.Decimal(18, 2)
  lineTotal       Decimal              @db.Decimal(18, 2)
  notes           String?              @db.Text
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([specificationId, lineNumber])
}

model ContractDocument {
  id         String               @id @default(cuid())
  contractId String
  contract   Contract             @relation(fields: [contractId], references: [id], onDelete: Cascade)
  type       ContractDocumentType
  fileName   String
  storageKey String
  mimeType   String
  htmlBody   String?              @db.Text
  pdfUrl     String?
  createdById String?
  createdAt  DateTime             @default(now())

  @@index([contractId, type, createdAt])
}

model ContractShareLink {
  id              String                  @id @default(cuid())
  contractId      String
  contract        Contract                @relation(fields: [contractId], references: [id], onDelete: Cascade)
  token           String                  @unique
  status          ContractShareLinkStatus @default(ACTIVE)
  expiresAt       DateTime
  maxViews        Int?
  viewCount       Int                     @default(0)
  lastViewedAt    DateTime?
  createdById     String?
  createdAt       DateTime                @default(now())
  revokedAt       DateTime?
  signatureSession SignatureSession?

  @@index([contractId, status, expiresAt])
}

model ContractAuditLog {
  id           String   @id @default(cuid())
  contractId   String
  contract     Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  action       String
  actorRole    String?
  actorUserId  String?
  payloadJson  Json?
  createdAt    DateTime @default(now())

  @@index([contractId, createdAt])
  @@index([action, createdAt])
}

model SignatureSession {
  id                String                 @id @default(cuid())
  contractId        String
  contract          Contract               @relation(fields: [contractId], references: [id], onDelete: Cascade)
  shareLinkId       String?                @unique
  shareLink         ContractShareLink?     @relation(fields: [shareLinkId], references: [id], onDelete: SetNull)
  provider          SignatureProvider      @default(DIIA)
  providerSessionId String                 @unique
  status            SignatureSessionStatus @default(CREATED)
  signingUrl        String?
  signedAt          DateTime?
  providerPayload   Json?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([contractId, status])
}

enum EnverContractStatus {
  DRAFT
  READY_FOR_REVIEW
  APPROVED_INTERNAL
  ISSUED
  SENT_FOR_SIGNATURE
  PARTIALLY_SIGNED
  SIGNED
  DECLINED
  EXPIRED
  VOIDED
}

enum EnverSignatureStatus {
  NOT_STARTED
  LINK_SENT
  OPENED
  IDENTIFIED
  SIGNING_IN_PROGRESS
  SIGNED
  FAILED
  CANCELLED
  EXPIRED
}

enum EnverContractPartyRole {
  CUSTOMER
  COMPANY
  GUARANTOR
}

enum EnverPartyType {
  INDIVIDUAL
  FOP
  LEGAL_ENTITY
}

enum EnverSignatureProvider {
  VCHASNO
  DIIA
  PAPERLESS
}

enum EnverTemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model EnverContractTemplate {
  id                  String              @id @default(cuid())
  code                String
  name                String
  documentType        String
  language            String              @default("uk")
  version             Int
  status              EnverTemplateStatus @default(DRAFT)
  bodyHtml            String?
  bodyDocxTemplateUrl String?
  variablesSchemaJson Json
  settingsJson        Json?
  approvalRequired    Boolean             @default(false)
  isActive            Boolean             @default(true)
  createdById         String?
  updatedById         String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  contracts EnverContract[]

  @@unique([code, version])
  @@index([code, status, isActive])
}

model EnverContract {
  id                  String                @id @default(cuid())
  contractNumber      String                @unique
  orderId             String
  dealId              String?
  clientId            String
  templateId          String
  templateCode        String
  templateVersion     Int
  status              EnverContractStatus   @default(DRAFT)
  signatureStatus     EnverSignatureStatus  @default(NOT_STARTED)
  provider            EnverSignatureProvider?
  payloadJson         Json
  pricingSnapshotJson Json?
  renderedHtmlHash    String?
  renderedPdfUrl      String?
  renderedPdfHash     String?
  issuedAt            DateTime?
  expiresAt           DateTime?
  signedAt            DateTime?
  cancelledAt         DateTime?
  createdById         String?
  updatedById         String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  template   EnverContractTemplate   @relation(fields: [templateId], references: [id], onDelete: Restrict)
  parties    EnverContractParty[]
  sessions   EnverSigningSession[]
  artifacts  EnverSignatureArtifact[]
  auditEvents EnverContractAuditEvent[]
  reminders  EnverContractReminder[]

  @@index([orderId])
  @@index([dealId])
  @@index([clientId])
  @@index([status, signatureStatus])
}

model EnverContractParty {
  id         String                @id @default(cuid())
  contractId String
  role       EnverContractPartyRole
  partyType  EnverPartyType
  fullName   String
  taxId      String?
  email      String?
  phone      String?
  signOrder  Int                   @default(1)
  mustSign   Boolean               @default(true)
  signStatus EnverSignatureStatus  @default(NOT_STARTED)
  signedAt   DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  contract EnverContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
}

model EnverSigningSession {
  id                  String                @id @default(cuid())
  contractId          String
  provider            EnverSignatureProvider
  providerEnvelopeId  String?
  providerSessionId   String?
  status              EnverSignatureStatus  @default(NOT_STARTED)
  startUrl            String?
  deepLink            String?
  qrCodeUrl           String?
  expiresAt           DateTime?
  lastWebhookAt       DateTime?
  providerPayloadJson Json?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  contract EnverContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, createdAt])
  @@index([provider, providerEnvelopeId])
}

model EnverSignatureArtifact {
  id                   String                @id @default(cuid())
  contractId           String
  partyId              String?
  provider             EnverSignatureProvider
  signatureType        String
  signedDocumentUrl    String?
  signatureContainerUrl String?
  verificationResultJson Json?
  certificateInfoJson  Json?
  hash                 String?
  timestampedAt        DateTime?
  createdAt            DateTime              @default(now())

  contract EnverContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, createdAt])
}

model EnverContractAuditEvent {
  id           String   @id @default(cuid())
  contractId   String
  eventType    String
  actorType    String?
  actorId      String?
  metadataJson Json?
  createdAt    DateTime @default(now())

  contract EnverContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, createdAt])
}

model EnverContractReminder {
  id           String   @id @default(cuid())
  contractId   String
  channel      String
  recipient    String
  scheduledAt  DateTime
  sentAt       DateTime?
  status       String   @default("PENDING")
  metadataJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contract EnverContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, status, scheduledAt])
}

model EnverContractSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  valueJson Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
