    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "bcryptjs": "2.4.3",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^4.1.0",
    "docx": "^9.6.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
