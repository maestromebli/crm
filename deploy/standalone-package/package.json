{
  "name": "crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev --webpack -p 3000",
    "dev:webpack": "next dev --webpack -p 3000",
    "dev:turbo": "next dev -p 3000",
    "dev:unlock": "node scripts/dev-unlock.mjs",
    "diagnose": "node scripts/diagnose.mjs",
    "build": "next build",
    "start": "next start",
