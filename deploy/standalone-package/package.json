    "db:seed-enver-contracts": "node scripts/seed-enver-contracts.mjs",
    "db:ensure-admin": "node scripts/ensure-admin.mjs",
    "db:check-admin": "node scripts/check-admin.mjs",
    "db:ensure-permissions": "node scripts/ensure-permission-rows.mjs",
    "audit:users": "node scripts/audit-users-access.mjs",
    "realign:permissions": "node scripts/realign-permissions-to-policy.mjs",
