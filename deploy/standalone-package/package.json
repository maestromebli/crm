    "e2e:nightly:critical": "playwright test tests/e2e/lead-hub-notes-stage-transition.spec.ts tests/e2e/lead-hub-notes-rbac.spec.ts tests/e2e/lead-hub-notes-rbac-api.spec.ts tests/e2e/contracts-portal-public-token-guard.spec.ts tests/e2e/contracts-portal-signing-happy-path.spec.ts tests/e2e/contracts-portal-status-transitions.spec.ts tests/e2e/contracts-portal-manager-sync.spec.ts tests/e2e/contracts-manager-document-generation.spec.ts",
