# ENVER CRM production env for enver.com.ua
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Main database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Auth
NEXTAUTH_URL="https://enver.com.ua"
NEXTAUTH_SECRET="generate-long-random-secret-32-plus-chars"

# Required app secrets
SIGNATURE_PROVIDER=mock
DIIA_WEBHOOK_SECRET="change-me"
CLIENT_PORTAL_TOKEN_SECRET="change-me-too"

# Session policy
AUTH_INACTIVITY_TIMEOUT_SECONDS=3600
AUTH_DAILY_REAUTH_SECONDS=86400
NEXT_PUBLIC_AUTH_INACTIVITY_TIMEOUT_SECONDS=3600
NEXT_PUBLIC_AUTH_DAILY_REAUTH_SECONDS=86400

# Optional integrations
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# AI_API_KEY=
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4.1-mini
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
# META_GRAPH_API_VERSION=v21.0
# META_AD_ACCOUNT_ID=act_123456789012345
# META_ACCESS_TOKEN=
